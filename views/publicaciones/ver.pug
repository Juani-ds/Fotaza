extends ../layout.pug

block content
    .max-w-3xl.mx-auto.mt-8.px-4
        .bg-white.rounded-lg.shadow.p-6
            .flex.justify-between.items-start.mb-4
                h1.text-2xl.font-bold= publicacion.titulo
                span.text-sm.text-gray-400 Por #{publicacion.Usuario.nombre}
            if publicacion.descripcion
                p.text-gray-600.mb-4= publicacion.descripcion
            if publicacion.Etiqueta && publicacion.Etiqueta.length > 0
                .flex.flex-wrap.gap-2.mb-4
                    each etiqueta in publicacion.Etiqueta
                        span.bg-gray-100.text-gray-600.px-2.py-1.rounded.text-sm= etiqueta.nombre
            if publicacion.Imagens
                each imagen in publicacion.Imagens
                    .mb-4
                        img.w-full.rounded(src=imagen.url)
        a.text-blue-500.mt-4.block(href='/') Volver