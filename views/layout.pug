doctype html
html(lang='es')
    head
        title Fotaza
        script(src='https://cdn.tailwindcss.com')
    body.bg-gray-100.min-h-screen
        nav.bg-white.shadow.p-4.flex.justify-between.items-center
            a.font-bold.text-xl(href='/') Fotaza
            form.flex.gap-1(method='GET' action='/publicaciones/buscar')
                input.border.rounded-full.px-3.py-1.text-sm(type='text' name='q' placeholder='Buscar...')
                button.bg-blue-500.text-white.px-3.py-1.rounded-full.text-sm(type='submit' class='hover:bg-blue-600') 🔍
            div
                if usuario
                    .relative.inline-block#menu-container
                        button.flex.items-center.gap-2.text-gray-700(type='button' id='menu-btn' class='hover:text-blue-500')
                            span= usuario.nombre
                            span ▾
                        .absolute.right-0.mt-2.bg-white.border.rounded.shadow-lg.hidden#menu-dropdown(style='min-width:150px')
                            a.block.px-4.py-2.text-sm(href='/usuarios/' + usuario.id class='hover:bg-gray-100') Mi perfil
                            a.block.px-4.py-2.text-sm(href='/auth/logout' class='hover:bg-gray-100 text-red-500') Cerrar sesión
                else
                    a.mr-4(href='/auth/login') Iniciar sesión
                    a.bg-blue-500.text-white.px-4.py-2.rounded(href='/auth/signup' class='hover:bg-blue-600') Registrarse
        main.p-8
            block content
        script.
            const btn = document.getElementById('menu-btn');
            const dropdown = document.getElementById('menu-dropdown');
            if (btn) {
                btn.addEventListener('click', () => dropdown.classList.toggle('hidden'));
                document.addEventListener('click', (e) => {
                    if (!document.getElementById('menu-container').contains(e.target)) {
                        dropdown.classList.add('hidden');
                    }
                });
            }